<Window x:Class="FINALPOE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Recipe Manager" Height="600" Width="800">
    <Grid>
        <StackPanel Margin="10">
            <TextBlock Text="Recipe Manager" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <!-- Add Recipe Section -->
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Add New Recipe" FontSize="16" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="NewRecipeNameTextBox" Width="200" Height="25" Margin="0,0,0,5" GotFocus="NewRecipeNameTextBox_GotFocus" Text="Recipe Name"/>
                <Button Content="Add Recipe" Width="100" Height="30" Click="AddRecipeButton_Click" HorizontalAlignment="Left" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Add Ingredient Section -->
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Add New Ingredient" FontSize="16" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="NewIngredientNameTextBox" Width="200" Height="25" Margin="0,0,0,5" GotFocus="NewIngredientNameTextBox_GotFocus" Text="Ingredient Name"/>
                <TextBox x:Name="NewIngredientCaloriesTextBox" Width="200" Height="25" Margin="0,0,0,5" GotFocus="NewIngredientCaloriesTextBox_GotFocus" Text="Calories"/>
                <TextBox x:Name="NewIngredientFoodGroupTextBox" Width="200" Height="25" Margin="0,0,0,5" GotFocus="NewIngredientFoodGroupTextBox_GotFocus" Text="Food Group"/>
                <Button Content="Add Ingredient" Width="100" Height="30" Click="AddIngredientButton_Click" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- Filter Recipes Section -->
            <StackPanel Orientation="Horizontal" Margin="0,20,0,10">
                <TextBox x:Name="IngredientTextBox" Width="150" Height="25" Margin="0,0,10,0" TextChanged="IngredientTextBox_TextChanged" Text="Ingredient"/>
                <ComboBox x:Name="FoodGroupComboBox" Width="150" Height="25" Margin="0,0,10,0"/>
                <Slider x:Name="CaloriesSlider" Width="150" Minimum="0" Maximum="1000" TickFrequency="100" IsSnapToTickEnabled="True" Value="500"/>
                <TextBlock x:Name="CaloriesValueTextBlock" Width="50" Text="{Binding ElementName=CaloriesSlider, Path=Value, StringFormat=F0}" Margin="5,0,0,0"/>
                <Button x:Name="FilterButton" Content="Filter Recipes" Width="100" Height="25" Click="FilterButton_Click"/>
            </StackPanel>

            <!-- Recipes DataGrid -->
            <DataGrid x:Name="RecipesDataGrid" AutoGenerateColumns="False" Margin="0,10,0,0" IsReadOnly="True" SelectionMode="Single" SelectionChanged="RecipesDataGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Recipe Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Total Calories" Binding="{Binding TotalCalories}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Ingredients DataGrid -->
            <DataGrid x:Name="IngredientsDataGrid" AutoGenerateColumns="False" Margin="0,10,0,0" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ingredient Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Calories" Binding="{Binding Calories}" Width="*"/>
                    <DataGridTextColumn Header="Food Group" Binding="{Binding FoodGroup}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Recipe Details and Pie Chart -->
            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <TextBlock x:Name="TotalCaloriesTextBlock" FontSize="16" FontWeight="Bold" Margin="0,10,0,5"/>
                <Button x:Name="ViewRecipeButton" Content="View Recipe Details" Width="150" Height="25" Margin="0,10,0,0" Click="ViewRecipeButton_Click"/>
                <lvc:PieChart x:Name="RecipePieChart" Margin="10,250,10,10"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>